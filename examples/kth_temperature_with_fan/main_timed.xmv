MODULE Globals
VAR
  "heater_on" : boolean;
  "in_kelvin" : integer;
  "out_celsius" : integer;
  "scheduler_state" : integer;

-- Generated Scheduler timing annotation:
VAR schedule_clock: clock;
INIT (schedule_clock = 0)
TRANS case
  (schedule_clock = f'2/1) : (next(schedule_clock) = 0);
  TRUE : (next(schedule_clock) = schedule_clock);
esac
INVAR (TRUE -> ((f'0/1 <= schedule_clock) & (schedule_clock <= f'2/1)))
INVAR (("scheduler_state" = 0) -> ((f'0/1 <= schedule_clock) & (schedule_clock <= f'0/1)))
INVAR (("scheduler_state" = 1) -> ((f'0/1 <= schedule_clock) & (schedule_clock <= f'1/2)))
INVAR (("scheduler_state" = 2) -> ((f'1/2 <= schedule_clock) & (schedule_clock <= f'1/2)))
INVAR (("scheduler_state" = 3) -> ((f'1/2 <= schedule_clock) & (schedule_clock <= f'1/1)))
INVAR (("scheduler_state" = 4) -> ((f'1/1 <= schedule_clock) & (schedule_clock <= f'1/1)))
INVAR (("scheduler_state" = 5) -> ((f'1/1 <= schedule_clock) & (schedule_clock <= f'2/1)))
URGENT ("scheduler_state" = 0)
URGENT ("scheduler_state" = 2)
URGENT ("scheduler_state" = 4)
JUSTICE ("scheduler_state" = 0)
JUSTICE ("scheduler_state" = 5)

-- #################### FALSE PROPERTIES ####################
-- unbounded

LTLSPEC -- disproving this shows that implications below are not vacuous
  !F(G[0,1]("out_celsius" < 0))

-- bounded
LTLSPEC -- too tight
  G(G[0,1]("out_celsius") < 0 -> F[0,1]("heater_on"))


-- #################### TRUE PROPERTIES ####################
-- bounded
LTLSPEC
  G(G[0,1]("out_celsius") < 0 -> F[0,2]("heater_on"))


MODULE main
VAR
  globals : Globals;
  entry : "`init.and.main"(globals."heater_on", globals."in_kelvin", globals."out_celsius", globals."scheduler_state");
