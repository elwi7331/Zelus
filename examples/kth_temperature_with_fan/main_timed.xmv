  __d129 := next("!{out_celsius}") = "%{out_celsius}#2";
  __d127 := next("!{in_kelvin}") = "!{$(in_main#0)<$(in_havoc_input#0)<h#<in_kelvin>>>}";
  __d118 := -1 * "%{out_celsius}#2";
  __d119 := "!{$(in_main#0)<$(in_havoc_input#0)<h#<in_kelvin>>>}" + __d118;
