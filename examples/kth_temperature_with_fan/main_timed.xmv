  __d158 := 0 <= "!{out_celsius}";
  __d165 := __d158 & __d163;
  __d159 := ! __d158;
  __d164 := __d159 & "%{heater_on}#2";
  __d166 := __d164 | __d165;
  __d169 := __d47 & __d166;
